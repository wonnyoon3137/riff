# KOPIS Open API — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 사용 금지(클라이언트 노출 방지).
KOPIS_BASE_URL=http://www.kopis.or.kr/openApi/restful
KOPIS_SERVICE_KEY=

# KOPIS 호출 타임아웃(ms)
KOPIS_TIMEOUT_MS=5000

# 공연장 마스터 동기화 주기(cron) — DEC-B: 주 1회 월요일 04:00 KST
VENUE_SYNC_CRON=0 4 * * 1

# venues 자체 DB(SQLite) 파일 경로. 미설정 시 ./data/venues.db
VENUE_DB_PATH=./data/venues.db

# POST /internal/sync-venues 보호 토큰(서버 전용). 미설정 시 로컬에서만 호출 허용.
VENUE_SYNC_TOKEN=

# Auth.js (NextAuth v5) — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 사용 금지.
# AUTH_SECRET: `npx auth secret` 로 생성 (32바이트 랜덤 문자열)
AUTH_SECRET=

# 카카오 OAuth (https://developers.kakao.com 앱 등록 후 발급)
# 로컬 redirect URI: http://localhost:3000/api/auth/callback/kakao
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# 구글 OAuth (https://console.cloud.google.com → OAuth 2.0 클라이언트 생성)
# 로컬 redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=